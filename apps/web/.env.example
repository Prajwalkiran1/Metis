NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Optional — Google Identity Services OAuth client ID.
# Leave blank to hide the "Sign in with Google" button entirely.
# Get one from https://console.cloud.google.com/apis/credentials (free).
# The backend must also have GOOGLE_CLIENT_ID set to the same value.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
